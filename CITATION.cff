        family-names: Nyström
      - given-names: Kenneth
        family-names: Holmqvist
    title: "An adaptive algorithm for fixation, saccade, and glissade detection in eyetracking data"
    journal: Behavior Research Methods
    year: 2010
    volume: 42
    issue: 1
    start: 188
    end: 204
    doi: 10.3758/BRM.42.1.188
